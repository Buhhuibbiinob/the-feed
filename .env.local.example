NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Project Settings > API > service_role key. Only used server-side, for admin
# actions like removing a user account — never expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Free key from https://www.last.fm/api/account/create — powers Trending
# Music on New Releases (Spotify's new-releases endpoint is deprecated for
# apps without their extended-quota approval).
LASTFM_API_KEY=
# Free key from https://www.themoviedb.org/settings/api — powers New Movies
# & TV on New Releases.
TMDB_API_KEY=
